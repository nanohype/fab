# fab environment — every operator-facing env var fab reads, grouped by
# concern. `grep -rn "process.env" src/` is the source of truth.

# ── Core credentials ──────────────────────────────────────────────────
# Anthropic API key — required for the managed-agents runtime (the default)
# and for Opus advisor escalations on every runtime.
ANTHROPIC_API_KEY=sk-ant-...
# GitHub PAT fallback for `fab repo add` when --token isn't passed.
# GITHUB_TOKEN=ghp_...

# ── Runtime seam (src/runtimes/index.ts) ──────────────────────────────
# Transport for role sessions: managed-agents (default) | sdk | sdk-k8s |
# claude-cli. Parity trade-offs in docs/transports.md.
# FAB_RUNTIME=managed-agents

# ── Inference seam (src/inference.ts, sdk runtime only) ───────────────
# Backend the in-process Agent SDK infers against: api (default) | bedrock |
# anthropic-aws.
# FAB_INFERENCE=api
# Required for FAB_INFERENCE=bedrock — the region whose cross-region
# inference profiles serve the models (us-*, eu-*, ap-*, us-gov-*).
# AWS_REGION=us-west-2
# Required for FAB_INFERENCE=anthropic-aws — the Claude Platform on AWS
# workspace id.
# ANTHROPIC_AWS_WORKSPACE_ID=

# ── Sandbox seam (src/sandbox.ts, managed-agents) ─────────────────────
# Where Managed Agents sessions execute: cloud (default) | self-hosted.
# self-hosted points the environment at adopter-hosted workers and skips
# native Memory (unsupported there).
# FAB_SANDBOX=cloud

# ── Skills + catalog (src/overlay.ts, src/skills.ts) ──────────────────
# Highest-priority skill overlay dir (then ~/.fab/skills/, <cwd>/.fab/skills/,
# bundled fab/skills/).
# FAB_SKILLS_DIR=
# Path to a local nanohype repo checkout — used as the brief-template
# fallback when no overlay base exists.
# NANOHYPE_PATH=

# ── Local state (src/state.ts, src/quality.ts) ────────────────────────
# Deployment/session state file (default: ~/.fab/state.json).
# FAB_STATE_FILE=
# Cross-engagement quality log (default: ~/.fab/quality.jsonl).
# FAB_QUALITY_FILE=

# ── MCP Gateway (protohype/mcp-gateway) ───────────────────────────────
# Single API Gateway hosts the switchboard services (/mcp/{service}).
# Bearer token auth. Required only if roles use the gateway-hosted servers.
MCP_GATEWAY_BASE_URL=
MCP_GATEWAY_TOKEN=

# ── MCP server URL overrides (src/mcp.ts, optional) ───────────────────
# Live endpoints use defaults. Override only if self-hosting.
#
# Live (no override needed):
# MCP_GITHUB_URL=https://api.githubcopilot.com/mcp/
# MCP_LINEAR_URL=https://mcp.linear.app/mcp
# MCP_SLACK_URL=https://mcp.slack.com/mcp
# MCP_NOTION_URL=https://mcp.notion.com/mcp
# MCP_SENTRY_URL=https://mcp.sentry.io/mcp/
# MCP_FIGMA_URL=https://mcp.figma.com/mcp
# MCP_HUNTER_URL=https://mcp.hunter.io/sse
#
# Gateway-hosted (route through MCP_GATEWAY_BASE_URL/mcp/{service} by default):
# MCP_HUBSPOT_URL=
# MCP_GDRIVE_URL=
# MCP_GCALENDAR_URL=
# MCP_ANALYTICS_URL=
# MCP_GCSE_URL=
# MCP_STRIPE_URL=
#
# Private MCP servers reachable through an MCP tunnel (the mcp-tunnel addon
# in eks-gitops) — comma-separated name=url pairs, https only, names must not
# shadow built-ins.
# FAB_MCP_TUNNEL="wiki=https://wiki.acme.tunnel.example/mcp"

# ── sdk-k8s dispatch (src/runtimes/sdk-k8s.ts) ────────────────────────
# All three required when FAB_RUNTIME=sdk-k8s; fab fails fast otherwise.
# Namespace holding the Platform CR (AgentSandbox CRs land here too).
# FAB_K8S_NAMESPACE=eks-agent-platform
# The fab image the session pod runs.
# FAB_K8S_SESSION_IMAGE=ghcr.io/nanohype/fab:latest
# The Platform the role-sessions run under.
# FAB_K8S_PLATFORM=
# Optional RuntimeClass for session pods — the gVisor/Kata isolation dial.
# FAB_K8S_RUNTIME_CLASS=
# (FAB_ROLE / FAB_MESSAGE are internal wire vars the dispatcher sets on each
# session pod — never set them by hand.)

# ── Per-session human attribution (src/attribution.ts, opt-in) ────────
# Bind each session's AWS + Kubernetes actions to a named human instead of
# the anonymous tenant IRSA role. Unset = unattributed (default).
# Requires platform IAM/RBAC — see docs/attribution.md before enabling.
# FAB_OPERATOR=alice@acme.com
# FAB_SESSION_ROLE_ARN=arn:aws:iam::<account-id>:role/<session-role>
# FAB_SESSION_DURATION=3600   # seconds, 900–3600 under role chaining

# ── claude-cli runtime knobs (src/runtimes/claude-cli.ts) ─────────────
# Pass --bare to every spawn (skip user CLAUDE.md/hooks/auto-memory; force
# ANTHROPIC_API_KEY auth) — default inherits the local Claude Code login.
# FAB_CLAUDE_BARE=1
# Binary lookup override (default: `claude` on PATH).
# FAB_CLAUDE_PATH=
# Space-separated flags appended to every spawn.
# FAB_CLAUDE_EXTRA_ARGS=
# Directory for per-session MCP config files (default: os.tmpdir()).
# FAB_CLAUDE_MCP_DIR=

# ── Service credentials ───────────────────────────────────────────────
# MCP upstream auth is injected by the vault at session time — see
# .env.vault and docs/VAULT_SETUP.md. No per-service secrets here.
